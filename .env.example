# Copy this file to .env and fill in real values. Never commit .env to GitHub.

# Long random string used to sign session cookies. Generate one with:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-string

# Local dev uses SQLite automatically. On Render, set DATABASE_URL to the
# Postgres connection string Render gives you and this will be used instead.
DATABASE_URL=

# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# Teachers must enter this code when registering, so random visitors can't
# sign up as a teacher. Share it only with your school's staff.
TEACHER_SIGNUP_CODE=change-this-code

# Max upload size in megabytes
MAX_UPLOAD_MB=20
